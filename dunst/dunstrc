[global]
    width = 300
    height = (0, 300)
    origin = top-right
    offset = (30, 20)
    notification_limit = 10
    font = Roboto 9
    format = "<b>%s</b>\n%b"
    alignment = left
    markup = full
    frame_color = "#bd93f9"
    frame_width = 1
    separator_color = frame
    separator_height = 2
    padding = 8
    horizontal_padding = 8
    icon_position = left
    max_icon_size = 64
    show_age_threshold = 60
    show_indicators = yes
    word_wrap = yes
    sort = yes
    idle_threshold = 120
    history_length = 20
    sticky_history = yes
    follow = mouse
    monitor = 0
    browser = xdg-open
    corner_radius = 0
    transparency = 15
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#282a36"
    foreground = "#f8f8f2"
    timeout = 5

[urgency_normal]
    background = "#282a36"
    foreground = "#f8f8f2"
    timeout = 5

[urgency_critical]
    background = "#282a36"
    foreground = "#ff5555"
    timeout = 0
