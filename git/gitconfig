[include]
    path = ~/.gitconfig_user
[merge]
    tool = nvimdiff
    conflictstyle = zdiff3
[mergetool]
    prompt = false
[push]
    default = upstream
    autoSetupRemote = true
[diff]
    tool = nvimdiff
    algorithm = histogram
    colorMoved = default
[difftool]
    prompt = false
[http]
    postBuffer = 524288000
[core]
    editor = nvim
    excludesfile = ~/.gitignore_global
[color]
    ui = auto
[init]
    defaultBranch = main
[transfer]
    fsckObjects = true
[pull]
    rebase = true
[fetch]
    prune = true
[rebase]
    autostash = true
    autosquash = true
[column]
    ui = auto
[branch]
    sort = -committerdate
[rerere]
    enabled = 1
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[interactive]
    diffFilter = delta --color-only
[pager]
    branch = false
    diff = delta
    log = delta
    show = delta
    blame = delta
[delta]
    line-numbers = true
    navigate = true
    syntax-theme = Dracula
[credential "https://github.com"]
    helper =
    helper = !/run/current-system/sw/bin/gh auth git-credential
[credential "https://gist.github.com"]
    helper =
    helper = !/run/current-system/sw/bin/gh auth git-credential
